{
  "name": "homescope-firebase-functions",
  "private": true,
  "version": "0.1.0",
  "description": "Firebase Functions for HomeScope GTA",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
