# Public site URL used for canonical URLs and metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-1G84P57QZY

# Email settings
EMAIL_PROVIDER=resend
EMAIL_ENABLED=true
LEADS_NOTIFICATION_EMAIL=yanginzburg@gmail.com
LEAD_EMAIL_SUBJECT=Homescope GTA LEAD

# Shared sender/from address for real providers
FROM_EMAIL=leads@yourdomain.com

# Provider secret (set when using a real provider)
RESEND_API_KEY=

# Firebase / Firestore (HomeScope project)
FIREBASE_PROJECT_ID=homescope-ee781
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_USE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=localhost:8080

# Optional Firebase Web config (public; only if frontend SDK is used)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=homescope-ee781
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Approved feed connector placeholders
FEED_SOURCE_SYSTEM=approved-mls-ddf
FEED_BASE_URL=
FEED_API_KEY=
FEED_USERNAME=
FEED_PASSWORD=
FEED_PAGE_SIZE=200

# Toronto Board DDF connector (server-only; never expose as NEXT_PUBLIC_*)
DDF_TOKEN_URL=
DDF_LISTINGS_URL=
DDF_REPLICATION_URL=
DDF_CLIENT_ID=
DDF_CLIENT_SECRET=
DDF_SCOPE=DDFApi_Read
DDF_TOP_PARAM=$top
DDF_SINCE_FILTER_FIELD=ModificationTimestamp
DDF_PAGE_SIZE=100
DDF_REQUEST_TIMEOUT_MS=60000
DDF_MAX_RETRIES=3

# MLS sync layer (modular connector + scheduler)
MLS_SOURCE_SYSTEM=toronto-board-ddf
MLS_CONNECTOR_KIND=ddf-treb
MLS_PAGE_SIZE=20
MLS_FULL_SYNC_MAX_PAGES_PER_RUN=5
MLS_SNAPSHOTS_ENABLED=true
MLS_CLEANUP_ENABLED=true
MLS_STRICT_PUBLIC_FIELDS=true
MLS_STALE_THRESHOLD_HOURS=48
MLS_SYNC_ADMIN_TOKEN=
MLS_SCHEDULER_TOKEN=

# Sync scheduler settings
SYNC_FULL_CRON=0 */3 * * *
SYNC_INCREMENTAL_CRON=
SYNC_CLEANUP_CRON=0 * * * *
SYNC_STALE_THRESHOLD_HOURS=48
