{
  "functions": {
    "source": "firebase/functions",
    "predeploy": [
      "npm --prefix firebase/functions install",
      "node firebase/functions/node_modules/typescript/bin/tsc -p firebase/functions/tsconfig.json"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
